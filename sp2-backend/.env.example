# === OpenAI (default) ===
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# === DeepSeek (or any Chat Completions-compatible provider) ===
# Uncomment the two lines below and set your key to use DeepSeek.
# Leave OPENAI_BASE_URL empty to use the default OpenAI Responses API.
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.deepseek.com
